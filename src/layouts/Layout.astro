---
import { getRelativeLocaleUrl } from 'astro:i18n';
import '../styles/global.css';
import { getT, locales, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
  pageKind?: 'manifesto' | 'about';
}

const { lang = defaultLocale, title, description, pageKind = 'manifesto' } = Astro.props;
const t = getT(lang);
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;

const cfBeaconToken = import.meta.env.PROD
  ? import.meta.env.PUBLIC_CF_BEACON_TOKEN
  : undefined;

const siteOrigin = Astro.site ?? new URL('/', Astro.url);
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const hreflangs = locales.map((l) => ({
  hreflang: l === 'pt' ? 'pt-PT' : 'en',
  href: new URL(getRelativeLocaleUrl(l, ''), siteOrigin).toString(),
}));
const xDefault = new URL(getRelativeLocaleUrl(defaultLocale, ''), siteOrigin).toString();

const websiteId = `${new URL(getRelativeLocaleUrl(defaultLocale, ''), siteOrigin).toString()}#website`;
const articleId = `${canonical}#manifesto`;
const aboutPageId = `${canonical}#about`;
const axiomsListId = `${canonical}#axioms`;

const personPublisher = {
  '@type': 'Person',
  name: 'Redeagle48',
  url: 'https://github.com/Redeagle48',
};

const websiteNode = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: new URL(getRelativeLocaleUrl(defaultLocale, ''), siteOrigin).toString(),
  name: 'TrueChangeFail (TCF)',
  alternateName: 'TCF',
  description:
    'Manifesto satírico sobre desenvolvimento OutSystems à pressa. 13 axiomas, 247 warnings, published anyway.',
  inLanguage: ['pt-PT', 'en'],
};

const manifestoGraph = [
  websiteNode,
  {
    '@type': 'Article',
    '@id': articleId,
    isPartOf: { '@id': websiteId },
    url: canonical,
    headline: pageTitle,
    description: pageDescription,
    inLanguage: t.htmlLang,
    datePublished: '2026-05-08',
    dateModified: '2026-05-09',
    author: personPublisher,
    publisher: personPublisher,
    keywords: [
      'OutSystems',
      'TrueChange',
      'manifesto',
      'satire',
      'GoHorse',
      'low-code',
      'ODC',
      'AI Mentor',
      'Architecture Dashboard',
    ],
    mainEntity: { '@id': axiomsListId },
  },
  {
    '@type': 'ItemList',
    '@id': axiomsListId,
    name: t.manifesto.heading,
    numberOfItems: t.manifesto.axioms.length,
    itemListOrder: 'https://schema.org/ItemListOrderAscending',
    itemListElement: t.manifesto.axioms.map((a, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      url: `${canonical}#axiom-${idx + 1}`,
      name: a.title,
      description: a.body,
    })),
  },
];

const aboutGraph = [
  websiteNode,
  {
    '@type': 'AboutPage',
    '@id': aboutPageId,
    isPartOf: { '@id': websiteId },
    url: canonical,
    name: pageTitle,
    description: pageDescription,
    inLanguage: t.htmlLang,
    datePublished: '2026-05-09',
    dateModified: '2026-05-09',
    author: personPublisher,
    publisher: personPublisher,
    about: { '@id': websiteId },
    significantLink: `${new URL(getRelativeLocaleUrl(lang, ''), siteOrigin).toString()}`,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': pageKind === 'about' ? aboutGraph : manifestoGraph,
};
---
<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/+/g, '/')} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    {hreflangs.map((h) => (
      <link rel="alternate" hreflang={h.hreflang} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <script is:inline set:html={`
(function(){
  var html = document.documentElement;
  function mark(k, v){ try { html.setAttribute("data-tcf-" + k, String(v)); } catch(_){} }
  try {
    var ptRe = /^pt(-|$)/i;
    var docLang = html.lang || "en";
    var isPt = ptRe.test(docLang);

    // Probe localStorage availability (Safari private mode, Brave shields, etc. throw on setItem).
    var lsOk = false;
    try {
      var probe = "__tcf_probe__";
      window.localStorage.setItem(probe, "1");
      window.localStorage.removeItem(probe);
      lsOk = true;
    } catch(e) { lsOk = false; }
    mark("ls", lsOk ? "1" : "0");

    var pref = null;
    if (lsOk) {
      try { pref = window.localStorage.getItem("tcf-lang"); } catch(e) {}
    }
    var browserLang = (navigator.languages && navigator.languages[0]) || navigator.language || "en";
    mark("browser", browserLang);

    if (!pref) {
      pref = ptRe.test(browserLang) ? "pt" : "en";
      if (lsOk) {
        try { window.localStorage.setItem("tcf-lang", pref); } catch(e) {}
      }
    }
    mark("pref", pref);
    mark("doc", docLang);

    if ((isPt && pref === "pt") || (!isPt && pref === "en")) {
      mark("action", "stay");
      return;
    }
    var targetHreflang = pref === "pt" ? "pt-PT" : "en";
    var link = document.querySelector('link[rel="alternate"][hreflang="' + targetHreflang + '"]');
    if (link && link.href) {
      // Strip origin so we stay on the current host (avoids dev → prod jumps).
      var targetPath;
      try {
        var u = new URL(link.href);
        targetPath = u.pathname + u.search + u.hash;
      } catch (_) {
        targetPath = link.getAttribute("href");
      }
      var currentPath = location.pathname + location.search + location.hash;
      if (targetPath && targetPath !== currentPath) {
        mark("action", "redirect");
        location.replace(targetPath);
      } else {
        mark("action", "same-path");
      }
    } else {
      mark("action", "no-alt");
    }
  } catch(e) {
    mark("error", (e && e.message) || e);
  }
})();
`} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={t.htmlLang.replace('-', '_')} />
    <meta property="og:site_name" content="TrueChangeFail" />
    <meta property="article:published_time" content="2026-05-08" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    {cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
      ></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
