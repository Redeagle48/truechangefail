---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getT, locales, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = getT(lang).switcher;
---
<nav class="lang-switcher" aria-label={t.label}>
  {locales.map((loc) => (
    <a
      href={getRelativeLocaleUrl(loc, '')}
      class:list={['lang-switcher__link', { 'is-active': loc === lang }]}
      aria-current={loc === lang ? 'page' : undefined}
      hreflang={loc}
    >
      {t[loc]}
    </a>
  ))}
</nav>

<style>
  .lang-switcher {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 50;
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.25rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    backdrop-filter: blur(6px);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .lang-switcher__link {
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    color: inherit;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.15s ease, background 0.15s ease;
  }
  .lang-switcher__link:hover {
    opacity: 1;
  }
  .lang-switcher__link.is-active {
    opacity: 1;
    background: rgba(255, 255, 255, 0.12);
  }
</style>
