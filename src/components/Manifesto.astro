---
import { getT, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = getT(lang).manifesto;
---
<section class="manifesto">
  <div class="shell">
    <div class="manifesto__head">
      <h2>{t.heading}</h2>
      <small>{t.axioms.length} {t.countSuffix}</small>
    </div>

    <ol class="axioms">
      {t.axioms.map((a, idx) => {
        const id = `axiom-${idx + 1}`;
        return (
          <li class="axiom" id={id}>
            <h3 class="axiom__title">
              <a class="axiom__anchor" href={`#${id}`} aria-label={`Link to ${a.title}`}>
                {a.title}
              </a>
            </h3>
            <p class="axiom__body">{a.body}</p>
          </li>
        );
      })}
    </ol>
  </div>
</section>
