---
import { getT, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const phrase = getT(lang).marquee;
const repeats = Array(8).fill(phrase);
---
<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    {repeats.map((p) => <span>{p}</span>)}
  </div>
</div>
