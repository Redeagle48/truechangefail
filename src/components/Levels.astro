---
import { getT, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = getT(lang).levels;
---
<section class="levels">
  <div class="shell">
    <div class="levels__head">
      <h2>{t.heading}</h2>
      <p style="margin-top:0.8rem;opacity:0.75;max-width:55ch">
        {t.intro}
      </p>
    </div>

    <div class="levels__grid">
      {t.items.map((l) => (
        <article class="level">
          <div class="level__rank">{l.rank}</div>
          <h3 class="level__name">{l.name}</h3>
          <p class="level__desc">{l.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
