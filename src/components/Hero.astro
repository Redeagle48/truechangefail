---
import { getT, type Locale, defaultLocale } from '../i18n/ui';

export interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = getT(lang).hero;
---
<header class="hero">
  <div class="shell">
    <div class="hero__meta reveal reveal-1">
      <span>{t.edition} · {t.year}</span>
      <span>{t.tag}</span>
    </div>

    <h1 class="hero__title reveal reveal-2">
      TRUE<br />
      <span class="strike">change</span><br />
      FAIL
    </h1>

    <p class="hero__sub reveal reveal-3">
      {t.sub}
    </p>

    <div class="hero__stamp reveal reveal-4" aria-hidden="true">
      <div>
        <span>{t.stampLine1}</span>
        {t.stampLine2}
      </div>
    </div>
  </div>
</header>
